{% sw_extends '@Storefront/storefront/layout/header/top-bar.html.twig' %}
{% block layout_header_top_bar %}
    <div class="top-bar d-none d-lg-flex">
        <div class="container">
            <div class="d-flex">
                <div class="top-bar-vibraplast-link">
                    <a href="{{ 'general.vibraplast-link.url'|trans }}"
                       target="_blank">
                        {{ 'general.vibraplast-link.name'|trans }}
                        {% sw_icon 'external-link' style {'pack' : 'WebwirkungIcons'} %}
                    </a>
                </div>
                {% block layout_header_service_menu %}
                    {{ parent() }}
                {% endblock %}
                <nav class="top-bar-nav">
                    {% block layout_header_top_bar_language %}
                        {{ parent() }}
                    {% endblock %}

                    {% block layout_header_top_bar_currency %}
                        {{ parent() }}
                    {% endblock %}
                </nav>
            </div>
        </div>
    </div>
{% endblock %}
