{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{% block layout_head_javascript_feature %}
    {{ parent() }}

    {% if config('WebwirkungVibraplastTheme.config.tagmanager') is not null %}
        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
							new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
						j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
						'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
					})(window,document,'script','dataLayer', '{{ config('WebwirkungVibraplastTheme.config.tagmanager')}}' );</script>
        <!-- End Google Tag Manager -->
    {% endif %}
{% endblock %}

{#noindex, nofollow for dev environment#}
{% block layout_head_meta_tags_robots %}{% if app.environment == 'dev' %}noindex,nofollow{% endif %}{% endblock %}
