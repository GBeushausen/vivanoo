{% sw_extends '@Storefront/storefront/layout/footer/footer.html.twig' %}

{% block layout_footer_inner_container %}
    <div class="vn-footer-inner">
        <div class="container">
            {% block layout_footer_navigation %}
                <div class="vn-footer-top">

                    {# ===== Brand + contact ===== #}
                    {% block layout_footer_navigation_hotline %}
                        <div class="vn-footer-brand">
                            <a href="{{ path('frontend.home.page') }}" class="vn-footer-logo">
                                <img src="{{ asset('bundles/vivanootheme/img/vivanoo-logo.png', 'asset') }}" alt="Vivanoo">
                            </a>
                            <p class="vn-footer-tagline">
                                vivanoo<sup>®</sup> ist der Concept Store von Vibraplast&nbsp;AG — sorgfältig kuratierte Produkte rund um Wohnen, Lifestyle und Genuss, online und in unserem Showroom in Aadorf.
                            </p>
                            {% block layout_footer_navigation_hotline_content %}
                                <div class="vn-footer-contact">
                                    <div class="vn-footer-contact-row">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="3"/></svg>
                                        <span>{{ 'footer.contact.address'|trans|raw }}</span>
                                    </div>
                                    <div class="vn-footer-contact-row">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
                                        <span>{{ 'footer.contact.email'|trans|raw }}</span>
                                    </div>
                                    <div class="vn-footer-contact-row">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7 13 13 0 0 0 .7 2.8 2 2 0 0 1-.5 2.1L8 9.7a16 16 0 0 0 6 6l1.1-1.2a2 2 0 0 1 2.1-.5 13 13 0 0 0 2.8.7A2 2 0 0 1 22 16.9z"/></svg>
                                        <span>{{ 'footer.contact.phone'|trans|raw }}</span>
                                    </div>
                                </div>
                            {% endblock %}
                        </div>
                    {% endblock %}

                    {# ===== Navigation columns from footer category tree =====
                       Limited to the first 3 root categories to keep the layout
                       in line with the design (brand + ~2-3 link cols + help).
                       Categories whose links duplicate the legal bottom-bar
                       (AGB / Datenschutz / Impressum / Widerruf — provided via
                       core.basicInformation pages) should be reordered or removed
                       in the Shopware admin. #}
                    {% block layout_footer_navigation_columns %}
                        {% for root in (page.footer.navigation.tree|slice(0, 2)) %}
                            {% set rootName = root.category.translated.name|lower %}
                            {% if rootName not in ['daten', 'legal', 'rechtliches'] %}
                                {% block layout_footer_navigation_column %}
                                    <div class="vn-footer-col">
                                        {% block layout_footer_navigation_information_headline %}
                                            <h6 class="vn-footer-col-title">
                                                {% if root.category.type == 'folder' %}
                                                    {{ root.category.translated.name }}
                                                {% else %}
                                                    <a href="{{ category_url(root.category) }}"
                                                       {% if category_linknewtab(root.category) %}target="_blank"{% endif %}
                                                       title="{{ root.category.translated.name }}">{{ root.category.translated.name }}</a>
                                                {% endif %}
                                            </h6>
                                        {% endblock %}

                                        {% if root.children|length > 0 %}
                                            {% block layout_footer_navigation_information_content %}
                                                <ul class="vn-footer-list">
                                                    {% for treeItem in root.children %}
                                                        {% set category = treeItem.category %}
                                                        {% set name = category.translated.name %}
                                                        {% block layout_footer_navigation_information_link_item %}
                                                            <li>
                                                                {% if category.type == 'folder' %}
                                                                    <span>{{ name }}</span>
                                                                {% else %}
                                                                    <a href="{{ category_url(category) }}"
                                                                       {% if category_linknewtab(category) %}target="_blank"{% endif %}
                                                                       title="{{ name }}">{{ name }}</a>
                                                                {% endif %}
                                                            </li>
                                                        {% endblock %}
                                                    {% endfor %}
                                                </ul>
                                            {% endblock %}
                                        {% endif %}
                                    </div>
                                {% endblock %}
                            {% endif %}
                        {% endfor %}
                    {% endblock %}

                    {# ===== Help / Direct contact card ===== #}
                    {% block layout_footer_navigation_request %}
                        <div class="vn-footer-help">
                            <h6 class="vn-footer-col-title">{{ 'footer.request.title'|trans|sw_sanitize }}</h6>
                            <div class="vn-footer-help-lede">Haben Sie Fragen oder eine Anfrage?</div>
                            <p>{{ 'footer.request.text'|trans|sw_sanitize }}</p>
                            <a class="vn-footer-help-btn"
                               href="{{ path('frontend.cms.page', { id: config('core.basicInformation.contactPage') }) }}">
                                Kontakt aufnehmen
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                            </a>
                        </div>
                    {% endblock %}
                </div>
            {% endblock %}

            {# ===== Bottom bar ===== #}
            {% block layout_footer_bottom %}
                <div class="vn-footer-bottom">
                    {% block layout_footer_copyright %}
                        <div class="vn-footer-copy">
                            &copy; {{ "now"|date("Y") }} Vivanoo&reg; · ein Concept Store von Vibraplast&nbsp;AG
                        </div>
                    {% endblock %}

                    {% block layout_footer_service_menu %}
                        <div class="vn-footer-legal">
                            {% if config('core.basicInformation.tosPage') %}
                                <a href="{{ path('frontend.cms.page', { id: config('core.basicInformation.tosPage') }) }}">AGB</a>
                            {% endif %}
                            {% if config('core.basicInformation.privacyPage') %}
                                <a href="{{ path('frontend.cms.page', { id: config('core.basicInformation.privacyPage') }) }}">Datenschutz</a>
                            {% endif %}
                            {% if config('core.basicInformation.imprintPage') %}
                                <a href="{{ path('frontend.cms.page', { id: config('core.basicInformation.imprintPage') }) }}">Impressum</a>
                            {% endif %}
                            {% if config('core.basicInformation.revocationPage') %}
                                <a href="{{ path('frontend.cms.page', { id: config('core.basicInformation.revocationPage') }) }}">Widerrufsbelehrung</a>
                            {% endif %}
                        </div>
                    {% endblock %}

                    <div class="vn-footer-socials">
                        {% if 'footer.social-link.instagram'|trans is not empty %}
                            <a class="vn-social-btn" href="{{ 'footer.social-link.instagram'|trans }}" target="_blank" rel="noopener" aria-label="Instagram">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                            </a>
                        {% endif %}
                        {% if 'footer.social-link.linkedin'|trans is not empty %}
                            <a class="vn-social-btn" href="{{ 'footer.social-link.linkedin'|trans }}" target="_blank" rel="noopener" aria-label="LinkedIn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22zM8 8h4.37v1.92h.06c.61-1.15 2.1-2.36 4.32-2.36 4.62 0 5.47 3.04 5.47 7v8.44h-4.56v-7.49c0-1.78-.03-4.07-2.48-4.07-2.48 0-2.86 1.94-2.86 3.94V22H8z"/></svg>
                            </a>
                        {% endif %}
                        {% if 'footer.social-link.youtube'|trans is not empty %}
                            <a class="vn-social-btn" href="{{ 'footer.social-link.youtube'|trans }}" target="_blank" rel="noopener" aria-label="YouTube">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21.6 7.2a2.5 2.5 0 0 0-1.7-1.8C18.2 5 12 5 12 5s-6.2 0-7.9.4A2.5 2.5 0 0 0 2.4 7.2 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.8 2.5 2.5 0 0 0 1.7 1.8C5.8 19 12 19 12 19s6.2 0 7.9-.4a2.5 2.5 0 0 0 1.7-1.8A26 26 0 0 0 22 12a26 26 0 0 0-.4-4.8zM10 15.5v-7l5.2 3.5z"/></svg>
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endblock %}
        </div>
    </div>
{% endblock %}

{% block layout_footer_payment_shipping_logos %}
{% endblock %}
