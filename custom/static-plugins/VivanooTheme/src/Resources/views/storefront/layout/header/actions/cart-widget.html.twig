{% sw_extends '@WebwirkungMinimumOrderSurchargePlugin/storefront/layout/header/actions/cart-widget.html.twig' %}

{% block layout_header_actions_cart_widget %}

    <span class="header-cart-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 4h2l2.4 12.3a2 2 0 0 0 2 1.7h8.7a2 2 0 0 0 2-1.6L22 8H6"/>
            <circle cx="9" cy="21" r="1.5"/>
            <circle cx="18" cy="21" r="1.5"/>
        </svg>
    </span>

    <span class="header-cart-label">
        {{ "checkout.cartTitle"|trans|striptags }}
    </span>

    {% set cartLineItems = [] %}

    {% for item in page.cart.lineItems %}
        {% if item.type != 'minimum-order-surcharge' %}
            {% set cartLineItems = cartLineItems|merge([item]) %}
        {% endif %}
    {% endfor %}

    {% if cartLineItems|length > 0 %}
        <span class="badge header-cart-badge">{{ cartLineItems|length }}</span>
    {% endif %}

    <span class="header-cart-total">
        {{ page.cart.price.positionPrice|currency }}{{ "general.star"|trans|sw_sanitize }}
    </span>

{% endblock %}
