{% sw_extends '@Storefront/storefront/component/checkout/cart-header.html.twig' %}
{% block component_checkout_cart_header_element %}
    <div class="card-title cart-table-header">
        <div class="row cart-header-row">
            {% block component_checkout_cart_header_product_info %}
                <div class="col-md-1 cart-header-article-number">
                    {{ "checkout.productnumber"|trans|sw_sanitize }}
                </div>
                <div class="col-md-6 cart-header-info">
                    {{ "checkout.cartHeaderInfo"|trans|sw_sanitize }}
                </div>
            {% endblock %}

            {% block component_checkout_cart_header_quantity %}
                <div class="col-md-2 cart-header-quantity">
                    {{ "checkout.cartHeaderQuantity"|trans|sw_sanitize }}
                </div>
            {% endblock %}

            {% block component_checkout_cart_header_total_price %}
                <div class="col-md-2 cart-header-total-price">
                    {{ "checkout.cartHeaderTotalPrice"|trans|sw_sanitize }}
                </div>
            {% endblock %}
        </div>
    </div>
{% endblock %}
