<div class="vn">

  <div class="vn-hero">
    <div class="vn-hero-tile vn-hero-primary">
      <div class="vn-hero-grid"></div>
      <div class="vn-hero-corner">SPRING DROP · 04 / 26</div>
      <div class="vn-hero-claim">
        <p class="vn-hero-eyebrow">Concept Store · powered by Vibraplast AG</p>
        <h1 class="vn-hero-title">weniger<br>Standard,<br><em>just wow.</em></h1>
        <p class="vn-hero-lead">Sorgfältig kuratierte Pieces für Zuhause, Küche, Reise und Alltag — handverlesen aus über 120 Manufakturen, geliefert in 1–2 Werktagen.</p>
        <div class="vn-hero-ctas">
          <a class="vn-btn vn-btn-primary" href="#">Kollektion entdecken
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a class="vn-btn vn-btn-ghost" href="#">Was ist neu?</a>
        </div>
      </div>
    </div>

    <div class="vn-hero-tile vn-hero-image vn-hero-main">
      <div class="vn-hero-ph vn-hero-ph-warm"></div>
      <div class="vn-hero-tag">hauptbild · campaign</div>
      <div class="vn-hero-caption"><span class="vn-hero-dot"></span>Frühlingsküche · Set ab CHF 89</div>
    </div>

    <div class="vn-hero-tile vn-hero-split">
      <div class="vn-hero-tile vn-hero-image vn-hero-mini">
        <div class="vn-hero-ph vn-hero-ph-cool"></div>
        <div class="vn-hero-tag">stimmungsbild · wohnen</div>
        <div class="vn-hero-caption"><span class="vn-hero-dot"></span>Slow living, Schweiz</div>
      </div>
      <div class="vn-hero-tile vn-hero-image vn-hero-mini">
        <div class="vn-hero-ph"></div>
        <div class="vn-hero-tag">stimmungsbild · reisen</div>
        <div class="vn-hero-caption"><span class="vn-hero-dot"></span>Weekender · neu</div>
      </div>
    </div>
  </div>

  <div class="vn-bar">
    <div class="vn-bar-item">
      <span class="vn-bar-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h13v10H2zM15 11h4l3 3v3h-7"/><circle cx="6" cy="19" r="2"/><circle cx="17" cy="19" r="2"/></svg>
      </span>
      <span class="vn-bar-text">
        <strong>Versandkostenfrei</strong>
        <span>ab CHF 75 in der Schweiz</span>
      </span>
    </div>
    <div class="vn-bar-item">
      <span class="vn-bar-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
      </span>
      <span class="vn-bar-text">
        <strong>1–2 Werktage</strong>
        <span>Lieferung CH-weit</span>
      </span>
    </div>
    <div class="vn-bar-item">
      <span class="vn-bar-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M12 3l2.6 5.6 6.4.7-4.7 4.5 1.3 6.2L12 17l-5.6 3 1.3-6.2L3 9.3l6.4-.7z"/></svg>
      </span>
      <span class="vn-bar-text">
        <strong>Kuratiert</strong>
        <span>von unserem Team in Aadorf</span>
      </span>
    </div>
    <div class="vn-bar-item">
      <span class="vn-bar-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-4 8-8 9-4-1-8-4-8-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
      </span>
      <span class="vn-bar-text">
        <strong>14 Tage</strong>
        <span>Rückgaberecht ohne Wenn &amp; Aber</span>
      </span>
    </div>
  </div>

  <div class="vn-editorial">
    <div class="vn-ed-img">
      <div class="vn-ed-img-tag">lifestyle · concept store aadorf</div>
      <div class="vn-ed-img-corner"><b>120+</b> kuratierte Marken</div>
    </div>
    <div class="vn-ed-text">
      <div class="vn-ed-tag">Unser Ansatz</div>
      <h2>Sorgfältig kuratiert.<br><em>Online &amp; offline.</em></h2>
      <p>In unserem Concept Store <b>vivanoo®</b> — powered by Vibraplast AG — entdecken Sie eine sorgfältig kuratierte Auswahl rund um Wohnen, Lifestyle und Genuss: von stilvollen Accessoires und praktischen Haushaltshelfern bis hin zu originellen Geschenkideen und smarten Gadgets.</p>
      <p>Was wir online führen, finden Sie auch in unserem Showroom in Aadorf — anfassen, vergleichen, beraten lassen.</p>
      <div class="vn-ed-stats">
        <div class="vn-ed-stat"><b>120+</b><span>Marken</span></div>
        <div class="vn-ed-stat"><b>4.9★</b><span>Kundenbewertung</span></div>
        <div class="vn-ed-stat"><b>9 J.</b><span>Konzept-Erfahrung</span></div>
      </div>
    </div>
  </div>

  {% set products = element.data.vars.products ?? null %}
  {% if products and products.count > 0 %}
    <section class="vn-products">
      <div class="vn-section-head">
        <div>
          <div class="vn-eyebrow">Sortiment</div>
          <h2 class="vn-section-title">Neu im <em>Sortiment.</em></h2>
        </div>
        <a href="#" class="vn-head-link">
          Alle Neuheiten
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="vn-product-grid">
        {% for product in products %}
          {% set productUrl = seoUrl('frontend.detail.page', { productId: product.id }) %}
          {% set coverUrl = product.cover.media.url ?? null %}
          {% set categoryName = product.categories|first.translated.name ?? null %}
          {% set price = product.price.first.gross ?? null %}
          {% set listPrice = product.price.first.listPrice.gross ?? null %}
          {% set hasStrike = listPrice and listPrice > price %}

          <article class="vn-product">
            <a href="{{ productUrl }}" class="vn-product-img" title="{{ product.translated.name }}">
              {% if coverUrl %}
                <img src="{{ coverUrl }}" alt="{{ product.translated.name }}" loading="lazy">
              {% else %}
                <div class="vn-product-ph"></div>
                <div class="vn-product-tag">produktbild</div>
              {% endif %}

              <div class="vn-product-badges">
                <span class="vn-badge vn-badge-new">Neu</span>
                {% if hasStrike %}<span class="vn-badge vn-badge-sale">Sale</span>{% endif %}
              </div>

              <div class="vn-product-quick">
                <span class="vn-quick-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
                  Details
                </span>
                <span class="vn-quick-btn vn-quick-cart">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 7V5a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v2"/><path d="M3 7h18l-1 13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/></svg>
                  In den Korb
                </span>
              </div>
            </a>

            <div class="vn-product-info">
              {% if categoryName %}<div class="vn-product-cat">{{ categoryName }}</div>{% endif %}
              <h4 class="vn-product-name">
                <a href="{{ productUrl }}">{{ product.translated.name }}</a>
              </h4>
              <div class="vn-product-row">
                {% if price %}
                  <div class="vn-product-price">
                    {% if hasStrike %}<span class="vn-product-strike">CHF {{ listPrice|number_format(2, '.', "'") }}</span>{% endif %}
                    CHF {{ price|number_format(2, '.', "'") }}
                  </div>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <section class="vn-quote">
    <div class="vn-quote-overlay"></div>
    <blockquote class="vn-quote-text">«Vivanoo® — <em>your choice,</em><br>on &amp; offline.»</blockquote>
    <div class="vn-quote-attr">Das Vivanoo-Versprechen</div>
  </section>

  <section class="vn-cats">
    <div class="vn-section-head">
      <div>
        <div class="vn-eyebrow">Welten entdecken</div>
        <h2 class="vn-section-title">Drei Welten, <em>ein Anspruch.</em></h2>
      </div>
      <a href="#" class="vn-head-link">
        Alle Kategorien
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="vn-cat-grid">
      <article class="vn-cat-card">
        <div class="vn-cat-visual"></div>
        <div class="vn-cat-num">01 / 03</div>
        <h3 class="vn-cat-title">Kochen &amp; Braten</h3>
        <p class="vn-cat-desc">Pfannen, Töpfe und alles für die perfekte Zubereitung — von Schweizer Klassikern bis japanischer Schmiedekunst.</p>
        <div class="vn-cat-tags">
          <span class="vn-cat-tag">Pfannen</span>
          <span class="vn-cat-tag">Töpfe</span>
          <span class="vn-cat-tag">Messer</span>
        </div>
        <a href="#" class="vn-cat-link">
          Sortiment entdecken
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </article>

      <article class="vn-cat-card">
        <div class="vn-cat-visual"></div>
        <div class="vn-cat-num">02 / 03</div>
        <h3 class="vn-cat-title">Küchenzubehör</h3>
        <p class="vn-cat-desc">Bretter, Utensilien, smarte Helfer — Werkzeug für jeden Tag, kuratiert für Haptik und Langlebigkeit.</p>
        <div class="vn-cat-tags">
          <span class="vn-cat-tag">Schneiden</span>
          <span class="vn-cat-tag">Backen</span>
          <span class="vn-cat-tag">Servieren</span>
        </div>
        <a href="#" class="vn-cat-link">
          Sortiment entdecken
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </article>

      <article class="vn-cat-card vn-cat-card-dark">
        <div class="vn-cat-visual"></div>
        <div class="vn-cat-num">03 / 03</div>
        <h3 class="vn-cat-title">Haushalt &amp; Ordnung</h3>
        <p class="vn-cat-desc">Aufbewahrung, Organisation und Helfer fürs Zuhause — damit jeder Raum seine eigene Ruhe findet.</p>
        <div class="vn-cat-tags">
          <span class="vn-cat-tag">Boxen</span>
          <span class="vn-cat-tag">Körbe</span>
          <span class="vn-cat-tag">Regale</span>
        </div>
        <a href="#" class="vn-cat-link">
          Sortiment entdecken
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </article>
    </div>
  </section>

  <section class="vn-visit">
    <div class="vn-visit-overlay"></div>
    <div class="vn-visit-text">
      <div class="vn-eyebrow vn-eyebrow-light">Showroom · Aadorf</div>
      <h3 class="vn-visit-title">Vom Bildschirm <em>direkt ins Regal.</em></h3>
      <p class="vn-visit-lead">Was Sie online sehen, können Sie bei uns auch anfassen. Unser Concept-Store-Team berät Sie gerne — auf einen Kaffee, ohne Termin.</p>

      <div class="vn-meta-list">
        <div class="vn-meta-item">
          <span class="vn-meta-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="3"/></svg>
          </span>
          <div>
            <div class="vn-meta-label">Adresse</div>
            <div class="vn-meta-value">Wittenwilerstrasse 25 · CH-8355 Aadorf</div>
          </div>
        </div>
        <div class="vn-meta-item">
          <span class="vn-meta-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </span>
          <div>
            <div class="vn-meta-label">Öffnungszeiten</div>
            <div class="vn-meta-value">Mo–Fr 9:00–18:30 · Sa 9:00–16:00</div>
          </div>
        </div>
        <div class="vn-meta-item">
          <span class="vn-meta-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7 13 13 0 0 0 .7 2.8 2 2 0 0 1-.5 2.1L8 9.7a16 16 0 0 0 6 6l1.1-1.2a2 2 0 0 1 2.1-.5 13 13 0 0 0 2.8.7A2 2 0 0 1 22 16.9z"/></svg>
          </span>
          <div>
            <div class="vn-meta-label">Direkter Kontakt</div>
            <div class="vn-meta-value">+41 (0) 52 368 00 50 · info@vivanoo.ch</div>
          </div>
        </div>
      </div>

      <div class="vn-visit-ctas">
        <a class="vn-btn vn-btn-primary" href="#">
          Anfahrt planen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="vn-btn vn-btn-ghost" href="#">Termin buchen</a>
      </div>
    </div>

    <div class="vn-visit-map">
      <div class="vn-visit-roads"></div>
      <div class="vn-visit-tag">map · zürich → aadorf · 35 min</div>
      <div class="vn-visit-card">
        <b>Vivanoo Showroom</b><br>
        Wittenwilerstrasse 25, Aadorf
        <div class="vn-visit-live">heute geöffnet bis 18:30</div>
      </div>
      <div class="vn-visit-pin"></div>
    </div>
  </section>

  <section class="vn-newsletter">
    <div class="vn-nl-text">
      <div class="vn-eyebrow">Newsletter</div>
      <h3 class="vn-nl-title">Neue Produkte. <em>Direkt ins Postfach.</em></h3>
      <p class="vn-nl-lead">Kein Spam. Nur ausgewählte Neuheiten, saisonale Highlights und gelegentlich eine gute Empfehlung. Abmeldung jederzeit möglich.</p>
    </div>
    <form class="vn-nl-form" action="#" method="post">
      <div class="vn-nl-row">
        <input class="vn-nl-input" type="email" name="email" placeholder="E-Mail-Adresse eingeben…" required>
        <button class="vn-nl-submit" type="submit">
          Abonnieren
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </button>
      </div>
      <label class="vn-nl-check">
        <input type="checkbox" required>
        <span>Ich habe die Datenschutzbestimmungen zur Kenntnis genommen und die AGB gelesen.</span>
      </label>
    </form>
  </section>

</div>
