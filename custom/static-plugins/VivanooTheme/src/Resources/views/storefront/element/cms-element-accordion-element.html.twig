{% block block_accordion_element %}
    <div class="accordion" id="accordion{{ element.id }}">
        <div class="accordion-item">
            <div class="accordion-header"
                id="heading{{ element.id }}">
                <button class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#collapse{{ element.id }}"
                        aria-expanded="false"
                        aria-controls="collapse{{ element.id }}">
                    {{ element.config.accordionTitle.value|raw }}
                </button>
            </div>
            <div id="collapse{{ element.id }}"
                 class="accordion-collapse collapse"
                 aria-labelledby="heading{{ element.id }}"
                 data-bs-parent="#accordion{{ element.id }}">
                <div class="accordion-body">
                    {{ element.config.accordionText.value|raw }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
