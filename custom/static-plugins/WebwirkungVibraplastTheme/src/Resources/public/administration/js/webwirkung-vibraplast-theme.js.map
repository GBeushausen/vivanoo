export default "{% block sw_cms_element_label_text_button %}\n    <div class=\"sw-cms-el-label-text-button\">\n        <div class=\"ww-label-element\">{{ $tc('sw-cms.elements.label-text-button.label') }}</div>\n\n        {{ element.config.label.value }}\n\n        <sw-text-editor\n                v-model=\"element.config.longText.value\"\n                :disabled=\"disabled\"\n                :allow-inline-data-mapping=\"true\"\n                :is-inline-edit=\"true\"\n                sanitize-input\n                enable-transparent-background\n                @input=\"onInput\"\n        />\n    </div>\n{% endblock %}\n";