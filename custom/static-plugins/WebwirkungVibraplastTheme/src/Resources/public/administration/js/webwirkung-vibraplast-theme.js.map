export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <div v-for='(historyItem, index) in element.config.historyItems.value' class=\"historyItem\">\n                    <h3>{{ $tc('sw-cms.elements.history-element.config.itemTitle') }} {{ historyItem.year }}</h3>\n                    <sw-text-field\n                            :key='historyItem.sort'\n                            v-model=\"historyItem.year\"\n                            :label=\"$tc('sw-cms.elements.history-element.config.yearText')\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-field>\n                    <sw-text-editor\n                            :key='historyItem.sort'\n                            v-model=\"historyItem.text\"\n                            :label=\"$tc('sw-cms.elements.history-element.config.text')\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-editor>\n                    {# Image #}\n                    <sw-upload-listener\n                            :upload-tag=\"'cms-block-media-config-history-image-' + index + '-' + element.id\"\n                            auto-upload\n                            @media-upload-finish=\"onFinishUploadHistoryImage($event, historyItem)\">\n                    </sw-upload-listener>\n                    <sw-media-compact-upload-v2\n                            :label=\"$tc('sw-cms.elements.history-element.config.historyImage')\"\n                            :source=\"historyImagePreviews[index]\"\n                            :upload-tag=\"'cms-block-media-config-history-image-' + index + '-' + element.id\"\n                            :default-folder=\"cmsPageState.pageEntityName\"\n                            file-accept=\"*/*\"\n                            @media-upload-remove-image=\"onRemoveHistoryImage(historyItem)\"\n                            @selection-change=\"onChangeHistoryImage($event, historyItem)\">\n                    </sw-media-compact-upload-v2>\n                </div>\n                <div>\n                    <sw-button v-if=\"counter < 8\" :disabled=\"false\" :square=\"false\" :block=\"false\" :isLoading=\"false\"\n                               size=\"small\"\n                               @click=\"onClickAddItem()\"\n                    >\n                        +\n                        {{ $tc('sw-cms.elements.history-element.config.addTextButton') }}\n                    </sw-button>\n                    <sw-button v-if=\"counter < 8\" :disabled=\"false\" :square=\"false\" :block=\"false\" :isLoading=\"false\"\n                               size=\"small\"\n                               @click=\"onClickRemoveItem()\"\n                    >\n                        -\n                        {{ $tc('sw-cms.elements.history-element.config.removeTextButton') }}\n                    </sw-button>\n                </div>\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";