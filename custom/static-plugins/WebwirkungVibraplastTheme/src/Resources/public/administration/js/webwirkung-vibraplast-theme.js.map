export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <div v-for='(sliderItem, index) in element.config.sliderItems.value' class=\"sliderItem\">\n                    <h3>{{ $tc('sw-cms.elements.header-slider-element.config.slideTitle') }} {{ index+1 }}</h3>\n                    <span>{{ $tc('sw-cms.elements.header-slider-element.config.priceLabel') }}</span>\n                    <div style=\"display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0 32px;\">\n                        <sw-select-field\n                                :label=\"$tc('sw-cms.elements.header-slider-element.config.pricePosition.label')\"\n                                v-model=\"sliderItem.pricePosition\"\n                        >\n                            <option value=\"top\">{{ $tc('sw-cms.elements.header-slider-element.config.pricePosition.top') }}</option>\n                            <option value=\"bottom\">{{ $tc('sw-cms.elements.header-slider-element.config.pricePosition.bottom') }}</option>\n                        </sw-select-field>\n                        <sw-text-field\n                                :key='sliderItem.sort'\n                                v-model=\"sliderItem.price\"\n                                :label=\"$tc('sw-cms.elements.header-slider-element.config.priceText')\"\n                                :allow-inline-data-mapping=\"true\"\n                        ></sw-text-field>\n                        <sw-text-field\n                                :key='sliderItem.sort'\n                                v-model=\"sliderItem.strikePrice\"\n                                :label=\"$tc('sw-cms.elements.header-slider-element.config.strikePriceText')\"\n                                :allow-inline-data-mapping=\"true\"\n                        ></sw-text-field>\n                    </div>\n\n                    <sw-text-field\n                            :key='sliderItem.sort'\n                            v-model=\"sliderItem.label\"\n                            :label=\"$tc('sw-cms.elements.header-slider-element.config.labelText')\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-field>\n                    <sw-text-editor\n                            :key='sliderItem.sort'\n                            v-model=\"sliderItem.text\"\n                            :label=\"$tc('sw-cms.elements.header-slider-element.config.text')\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-editor>\n\n{#                  Overlay Image #}\n                    <sw-upload-listener\n                            :upload-tag=\"'cms-block-media-config-slide-overlay-' + index + '-' + element.id\"\n                            auto-upload\n                            @media-upload-finish=\"onFinishUploadSlideOverlayMedia($event, sliderItem)\">\n                    </sw-upload-listener>\n                    <sw-media-compact-upload-v2\n                            :label=\"$tc('sw-cms.elements.header-slider-element.config.overlayMedia')\"\n                            :source=\"slideOverlayMediaPreviews[index]\"\n                            :upload-tag=\"'cms-block-media-config-slide-overlay-' + index + '-' + element.id\"\n                            :default-folder=\"cmsPageState.pageEntityName\"\n                            {# file-accept=\"image/*,video/*\" #}\n                            {# Temporary fix for NEXT-22952 #}\n                            file-accept=\"*/*\"\n                            @media-upload-remove-image=\"onRemoveSlideOverlayMedia(sliderItem)\"\n                            @selection-change=\"onChangeSlideOverlayMedia($event, sliderItem)\">\n                    </sw-media-compact-upload-v2>\n\n{#                  Background Image #}\n                    <sw-upload-listener\n                            :upload-tag=\"'cms-block-media-config-slide-background-' + index + '-' + element.id\"\n                            auto-upload\n                            @media-upload-finish=\"onFinishUploadSlideBackgroundMedia($event, sliderItem)\">\n                    </sw-upload-listener>\n                    <sw-media-compact-upload-v2\n                            :label=\"$tc('sw-cms.elements.header-slider-element.config.backgroundMedia')\"\n                            :source=\"slideBackgroundMediaPreviews[index]\"\n                            :upload-tag=\"'cms-block-media-config-slide-background-' + index + '-' + element.id\"\n                            :default-folder=\"cmsPageState.pageEntityName\"\n                            {# file-accept=\"image/*,video/*\" #}\n                            {# Temporary fix for NEXT-22952 #}\n                            file-accept=\"*/*\"\n                            @media-upload-remove-image=\"onRemoveSlideBackgroundMedia(sliderItem)\"\n                            @selection-change=\"onChangeSlideBackgroundMedia($event, sliderItem)\">\n                    </sw-media-compact-upload-v2>\n                </div>\n                <div>\n                    <sw-button v-if=\"counter < 8\" :disabled=\"false\" :square=\"false\" :block=\"false\" :isLoading=\"false\"\n                               size=\"small\"\n                               @click=\"onClickAddSlide()\"\n                    >\n                        +\n                        {{ $tc('sw-cms.elements.header-slider-element.config.addTextButton') }}\n                    </sw-button>\n                    <sw-button v-if=\"counter < 8\" :disabled=\"false\" :square=\"false\" :block=\"false\" :isLoading=\"false\"\n                               size=\"small\"\n                               @click=\"onClickRemoveSlide()\"\n                    >\n                        -\n                        {{ $tc('sw-cms.elements.header-slider-element.config.removeTextButton') }}\n                    </sw-button>\n                </div>\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";