export default "{% block sw_cms_section_config_name_field %}\n    {% parent %}\n\n    {% block sw_cms_sidebar_section_config_background_type_field %}\n        <webwirkung-background-types :parent=\"section\"></webwirkung-background-types>\n    {% endblock %}\n{% endblock %}\n\n\n{% block sw_cms_sidebar_section_config_sizing_field %}\n    <sw-select-field\n            {% if VUE3 %}\n                v-model:value=\"section.sizingMode\"\n            {% else %}\n                v-model=\"section.sizingMode\"\n            {% endif %}\n            :label=\"$tc('sw-cms.detail.label.sizingField')\"\n    >\n        <option value=\"boxed\">\n            {{ $tc('sw-cms.detail.label.sizingOptionBoxed') }}\n        </option>\n        <option value=\"full_width\">\n            {{ $tc('sw-cms.detail.label.sizingOptionFull') }}\n        </option>\n        <option value=\"narrow\">\n            {{ $tc('sw-cms.detail.label.sizingOptionNarrow') }}\n        </option>\n    </sw-select-field>\n{% endblock %}";