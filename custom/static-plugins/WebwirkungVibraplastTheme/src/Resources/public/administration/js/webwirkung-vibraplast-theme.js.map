export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n\n                    {% block sw_cms_element_double_image_overlay_one %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadOverlayImageOneTag\"\n                                :source=\"previewOverlayImageOneSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.double-image-element.config.caption.overlayImageOneUpload')\"\n                                @media-upload-sidebar-open=\"onOpenOverlayImageOneModal\"\n                                @media-upload-remove-image=\"onOverlayImageOneRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadOverlayImageOneTag\"\n                                auto-upload\n                                @media-upload-finish=\"onOverlayImageOneUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"overlayImageOneModalIsOpen\"\n                                variant=\"regular\"\n                                :caption=\"$tc('sw-cms.elements.double-image-element.config.caption.overlayImageOneUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onOverlayImageOneRemove\"\n                                @media-modal-selection-change=\"onOverlayImageOneSelectionChanges\"\n                                @modal-close=\"onCloseOverlayImageOneModal\"\n                        ></sw-media-modal-v2>\n                        <br><br>\n                    {% endblock %}\n\n                    {% block sw_cms_element_double_image_overlay_two %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadOverlayImageTwoTag\"\n                                :source=\"previewOverlayImageTwoSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.double-image-element.config.caption.overlayImageTwoUpload')\"\n                                @media-upload-sidebar-open=\"onOpenOverlayImageTwoModal\"\n                                @media-upload-remove-image=\"onOverlayImageTwoRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadOverlayImageTwoTag\"\n                                auto-upload\n                                @media-upload-finish=\"onOverlayImageTwoUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"overlayImageTwoModalIsOpen\"\n                                variant=\"regular\"\n                                :caption=\"$tc('sw-cms.elements.double-image-element.config.caption.overlayImageTwoUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onOverlayImageTwoRemove\"\n                                @media-modal-selection-change=\"onOverlayImageTwoSelectionChanges\"\n                                @modal-close=\"onCloseOverlayImageTwoModal\"\n                        ></sw-media-modal-v2>\n                        <br><br>\n                    {% endblock %}\n\n                    {% block sw_cms_element_double_image_background %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadBackgroundImageTag\"\n                                :source=\"previewBackgroundImageSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.double-image-element.config.caption.backgroundImageUpload')\"\n                                @media-upload-sidebar-open=\"onOpenBackgroundImageModal\"\n                                @media-upload-remove-image=\"onBackgroundImageRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadBackgroundImageTag\"\n                                auto-upload\n                                @media-upload-finish=\"onBackgroundImageUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"backgroundImageModalIsOpen\"\n                                variant=\"regular\"\n                                :caption=\"$tc('sw-cms.elements.double-image-element.config.caption.backgroundImageUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onBackgroundImageRemove\"\n                                @media-modal-selection-change=\"onBackgroundImageSelectionChanges\"\n                                @modal-close=\"onCloseBackgroundImageModal\"\n                        ></sw-media-modal-v2>\n                    {% endblock %}\n\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";