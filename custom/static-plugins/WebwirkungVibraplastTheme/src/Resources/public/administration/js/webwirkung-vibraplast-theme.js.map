export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <div v-for='(stepByStepItem, index) in element.config.stepByStepItems.value' class=\"stepByStepItem\">\n                    <h3>{{ $tc('sw-cms.elements.step-by-step-element.config.stepTitle') }} {{ index+1 }}</h3>\n                    <sw-text-field\n                            :key='stepByStepItem.sort'\n                            v-model=\"stepByStepItem.title\"\n                            :label=\"$tc('sw-cms.elements.step-by-step-element.config.title')\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-field>\n                    <sw-text-editor\n                            :key='stepByStepItem.sort'\n                            v-model=\"stepByStepItem.text\"\n                            :label=\"$tc('sw-cms.elements.step-by-step-element.config.text')\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-editor>\n                </div>\n                <div>\n                    <sw-button v-if=\"counter < 8\" :disabled=\"false\" :square=\"false\" :block=\"false\" :isLoading=\"false\"\n                               size=\"small\"\n                               @click=\"onClickAddSlide()\"\n                    >\n                        +\n                        {{ $tc('sw-cms.elements.step-by-step-element.config.addTextButton') }}\n                    </sw-button>\n                    <sw-button v-if=\"counter < 8\" :disabled=\"false\" :square=\"false\" :block=\"false\" :isLoading=\"false\"\n                               size=\"small\"\n                               @click=\"onClickRemoveSlide()\"\n                    >\n                        -\n                        {{ $tc('sw-cms.elements.step-by-step-element.config.removeTextButton') }}\n                    </sw-button>\n                </div>\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";