              :caption=\"$tc('sw-cms.elements.five-image-element.config.caption.backgroundImageUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onBackgroundImageRemove\"\n                                @media-modal-selection-change=\"onBackgroundImageSelectionChanges\"\n                                @modal-close=\"onCloseBackgroundImageModal\"\n                        ></sw-media-modal-v2>\n                    {% endblock %}\n\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";