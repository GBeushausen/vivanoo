export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n\n                    {% block sw_cms_element_five_image_overlay_one %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadFiveImageOneTag\"\n                                :source=\"previewFiveImageOneSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.five-image-element.config.caption.fiveImageOneUpload')\"\n                                @media-upload-sidebar-open=\"onOpenFiveImageOneModal\"\n                                @media-upload-remove-image=\"onFiveImageOneRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadFiveImageOneTag\"\n                                auto-upload\n                                @media-upload-finish=\"onFiveImageOneUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"fiveImageOneModalIsOpen\"\n                        