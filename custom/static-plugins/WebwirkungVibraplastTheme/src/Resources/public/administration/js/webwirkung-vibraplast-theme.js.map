export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                    <sw-text-field\n                            v-model=\"heroTitle\"\n                            label=\"Titel\"\n                            :allow-inline-data-mapping=\"true\"\n                    ></sw-text-field>\n                    <sw-text-editor\n                            v-model=\"heroText\"\n                            label=\"Text\"\n                    ></sw-text-editor>\n\n                    {% block sw_cms_element_hero_header_image %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadHeroImageTag\"\n                                :source=\"previewHeroImageSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.hero-header-element.config.caption.heroImageUpload')\"\n                                @media-upload-sidebar-open=\"onOpenHeroImageModal\"\n                                @media-upload-remove-image=\"onHeroImageRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadHeroImageTag\"\n                                auto-upload\n                                @media-upload-finish=\"onHeroImageUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"heroImageModalIsOpen\"\n                                variant=\"regular\"\n                                :caption=\"$tc('sw-cms.elements.hero-header-element.config.caption.heroImageUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onHeroImageRemove\"\n                                @media-modal-selection-change=\"onHeroImageSelectionChanges\"\n                                @modal-close=\"onCloseHeroImageModal\"\n                        ></sw-media-modal-v2>\n                        <br><br>\n                    {% endblock %}\n\n                    {% block sw_cms_element_hero_header_background %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadHeroBackgroundTag\"\n                                :source=\"previewHeroBackgroundSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.hero-header-element.config.caption.heroBackgroundUpload')\"\n                                @media-upload-sidebar-open=\"onOpenHeroBackgroundModal\"\n                                @media-upload-remove-image=\"onHeroBackgroundRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadHeroBackgroundTag\"\n                                auto-upload\n                                @media-upload-finish=\"onHeroBackgroundUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"heroBackgroundModalIsOpen\"\n                                variant=\"regular\"\n                                :caption=\"$tc('sw-cms.elements.hero-header-element.config.caption.heroBackgroundUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onHeroBackgroundRemove\"\n                                @media-modal-selection-change=\"onHeroBackgroundSelectionChanges\"\n                                @modal-close=\"onCloseHeroBackgroundModal\"\n                        ></sw-media-modal-v2>\n                    {% endblock %}\n\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";