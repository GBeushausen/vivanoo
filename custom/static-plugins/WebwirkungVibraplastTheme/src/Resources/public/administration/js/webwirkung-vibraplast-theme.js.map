export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <sw-text-field\n                        v-model=\"tableLabel\"\n                        :label=\"$tc('sw-cms.elements.table-of-contents-element.config.tableLabel')\"\n                        :allow-inline-data-mapping=\"true\"\n                ></sw-text-field>\n                <sw-select-field\n                        :label=\"$tc('sw-cms.elements.table-of-contents-element.config.titleType.label')\"\n                        v-model=\"titleType\"\n                >\n                    <option value=\"h2\">{{ $tc('sw-cms.elements.table-of-contents-element.config.titleType.h2') }}</option>\n                    <option value=\"h3\">{{ $tc('sw-cms.elements.table-of-contents-element.config.titleType.h3') }}</option>\n                    <option value=\"h4\">{{ $tc('sw-cms.elements.table-of-contents-element.config.titleType.h4') }}</option>\n                </sw-select-field>\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";