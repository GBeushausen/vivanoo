r\"\n                                :caption=\"$tc('sw-cms.elements.five-image-element.config.caption.fiveImageTwoUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onFiveImageTwoRemove\"\n                                @media-modal-selection-change=\"onFiveImageTwoSelectionChanges\"\n                                @modal-close=\"onCloseFiveImageTwoModal\"\n                        ></sw-media-modal-v2>\n                        <br><br>\n                    {% endblock %}\n\n                    {% block sw_cms_element_five_image_overlay_three %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadFiveImageThreeTag\"\n                                :source=\"previewFiveImageThreeSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.five-image-element.config.caption.fiveImageThreeUpload')\"\n                                @media-upload-sidebar-open=\"onOpenFiveImageThreeModal\"\n                                @media-upload-remove-image=\"onFiveImageThreeRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadFiveImageThreeTag\"\n                                auto-upload\n                                @media-upload-finish=\"onFiveImageThreeUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"fiveImageThreeModalIsOpen\"\n                                variant=\"regular\"\n                                :caption=\"$tc('sw-cms.elements.five-image-element.config.caption.fiveImageThreeUpload')\"\n                                :entity-context=\"cmsPageState.entityName\"\n                                :allow-multi-select=\"false\"\n                                :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                                @media-upload-remove-image=\"onFiveImageThreeRemove\"\n                                @media-modal-selection-change=\"onFiveImageThreeSelectionChanges\"\n                                @modal-close=\"onCloseFiveImageThreeModal\"\n                        ></sw-media-modal-v2>\n                        <br><br>\n                    {% endblock %}\n\n                    {% block sw_cms_element_five_image_overlay_four %}\n                        <sw-media-upload-v2\n                                variant=\"regular\"\n                                :upload-tag=\"uploadFiveImageFourTag\"\n                                :source=\"previewFiveImageFourSource\"\n                                :allow-multi-select=\"false\"\n                                :default-folder=\"cmsPageState.pageEntityName\"\n                                :label=\"$tc('sw-cms.elements.five-image-element.config.caption.fiveImageFourUpload')\"\n                                @media-upload-sidebar-open=\"onOpenFiveImageFourModal\"\n                                @media-upload-remove-image=\"onFiveImageFourRemove\"\n                        ></sw-media-upload-v2>\n                        <sw-upload-listener\n                                :upload-tag=\"uploadFiveImageFourTag\"\n                                auto-upload\n                                @media-upload-finish=\"onFiveImageFourUpload\"\n                        ></sw-upload-listener>\n                        <sw-media-modal-v2\n                                v-if=\"fiveImageFourModalIsOpen\"\n                                variant=\"regular\"\n        