export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <sw-media-upload-v2\n                        variant=\"regular\"\n                        :upload-tag=\"uploadimageCaptionImageTag\"\n                        :source=\"previewimageCaptionImageSource\"\n                        :allow-multi-select=\"false\"\n                        :default-folder=\"cmsPageState.pageEntityName\"\n                        :label=\"$tc('sw-cms.elements.image-caption-element.config.imageCaptionImage')\"\n                        @media-upload-sidebar-open=\"onOpenimageCaptionImageModal\"\n                        @media-upload-remove-image=\"onimageCaptionImageRemove\"\n                ></sw-media-upload-v2>\n                <sw-upload-listener\n                        :upload-tag=\"uploadimageCaptionImageTag\"\n                        auto-upload\n                        @media-upload-finish=\"onimageCaptionImageUpload\"\n                ></sw-upload-listener>\n                <sw-media-modal-v2\n                        v-if=\"imageCaptionImageModalIsOpen\"\n                        variant=\"regular\"\n                        :caption=\"$tc('sw-cms.elements.image-caption-element.config.image')\"\n                        :entity-context=\"cmsPageState.entityName\"\n                        :allow-multi-select=\"false\"\n                        :initial-folder-id=\"cmsPageState.defaultMediaFolderId\"\n                        @media-upload-remove-image=\"onimageCaptionImageRemove\"\n                        @media-modal-selection-change=\"onimageCaptionImageSelectionChanges\"\n                        @modal-close=\"onCloseimageCaptionImageModal\"\n                ></sw-media-modal-v2>\n                <br><br>\n                <sw-text-field\n                        v-model=\"imageCaption\"\n                        class=\"ww-text-field\"\n                        :label=\"$tc('sw-cms.elements.image-caption-element.config.imageCaption')\"\n                        @input=\"onElementUpdateContent\"\n                        @change=\"onElementUpdateContent\"\n                ></sw-text-field>\n\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";