export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <sw-select-field\n                        :label=\"$tc('sw-cms.elements.label-text-button.config.alignment.label')\"\n                        v-model=\"alignment\"\n                >\n                    <option value=\"left\">{{ $tc('sw-cms.elements.label-text-button.config.alignment.left') }}</option>\n                    <option value=\"center\">{{ $tc('sw-cms.elements.label-text-button.config.alignment.center') }}</option>\n                </sw-select-field>\n                <sw-text-field\n                        v-model=\"label\"\n                        class=\"swag-iframe-field\"\n                        label=\"Label\"\n                        @input=\"onElementUpdateContent\"\n                        @change=\"onElementUpdateContent\">\n                </sw-text-field>\n                <sw-text-editor\n                        v-model=\"longText\"\n                        class=\"swag-iframe-field\"\n                        label=\"Text\"\n                        @input=\"onElementUpdateContent\"\n                        @change=\"onElementUpdateContent\"\n                />\n\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";