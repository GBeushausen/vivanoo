export default "<div>\n    <sw-tabs\n            class=\"sw-cms-el-config-text__tabs\"\n            default-item=\"content\"\n    >\n        <template slot-scope=\"{ active }\">\n\n            <sw-tabs-item\n                    :title=\"$tc('sw-cms.elements.general.config.tab.content')\"\n                    name=\"content\"\n                    :active-tab=\"active\"\n            >\n                {{ $tc('sw-cms.elements.general.config.tab.content') }}\n            </sw-tabs-item>\n        </template>\n\n        <template\n                slot=\"content\"\n                slot-scope=\"{ active }\"\n        >\n\n            <sw-container\n                    v-if=\"active === 'content'\"\n                    class=\"sw-cms-el-config-text__tab-content\"\n            >\n                <sw-select-field\n                        :label=\"$tc('sw-cms.elements.category-listing-element.config.columns.label')\"\n                        v-model=\"columns\"\n                >\n                    <option value=\"3\">{{ $tc('sw-cms.elements.category-listing-element.config.columns.three') }}</option>\n                    <option value=\"2\">{{ $tc('sw-cms.elements.category-listing-element.config.columns.two') }}</option>\n                </sw-select-field>\n                <sw-entity-multi-select\n                        {% if VUE3 %}\n                            v-model:entityCollection=\"categoryCollection\"\n                        {% else %}\n                            v-model=\"categoryCollection\"\n                        {% endif %}\n                        class=\"sw-cms-el-config-product-slider__products\"\n                        :label=\"$tc('sw-cms.elements.category-listing-element.config.label.selection')\"\n                        :placeholder=\"$tc('sw-cms.elements.category-listing-element.config.placeholder.selection')\"\n                        :context=\"categoryMultiSelectContext\"\n                        {% if VUE3 %}\n                            @update:entity-collection=\"onCategoriesChange\"\n                        {% else %}\n                            @change=\"onCategoriesChange\"\n                        {% endif %}\n                >\n                    <template #selection-label-property=\"{ item }\">\n                            {{ item.translated.name || item.name }}\n                    </template>\n                    <template #result-item=\"{ item, index }\">\n                        <slot\n                                name=\"result-item\"\n                                v-bind=\"{ item, index }\"\n                        >\n                            <sw-select-result\n                                    v-bind=\"{ item, index, selected: isSelected(item.id)}\"\n                            >\n                                \n                                {% block sw_entity_single_select_base_results_list_result_label %}\n                                    <span class=\"sw-select-result__result-item-text\">\n                                        {{ item.translated.name || item.name }}\n                                    </span>\n                                {% endblock %}\n                            </sw-select-result>\n                        </slot>\n                    </template>\n                </sw-entity-multi-select>\n\n            </sw-container>\n        </template>\n    </sw-tabs>\n</div>";