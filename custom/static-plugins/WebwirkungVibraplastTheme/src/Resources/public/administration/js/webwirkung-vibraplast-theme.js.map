export default "{% block sw_order_line_items_grid_grid_columns_label %}\n    {% parent %}\n\n    <template v-for=\"configuratorOptionsSlot in configuratorOptionsColumnsSlots\"\n              #[configuratorOptionsSlot.slotName]=\"{ item }\">\n\n        <template v-if=\"item.payload.configuratorOptions && item.payload.configuratorOptions[configuratorOptionsSlot.optionId]\">\n            {{ item.payload.configuratorOptions[configuratorOptionsSlot.optionId].value }}\n        </template>\n\n        <template v-if=\"item.payload.variantPropertyOptionData && item.payload.variantPropertyOptionData.groupId ==configuratorOptionsSlot.optionId\">\n            {{ item.payload.variantPropertyOptionData.name }}\n        </template>\n    </template>\n{% endblock %}\n\n";