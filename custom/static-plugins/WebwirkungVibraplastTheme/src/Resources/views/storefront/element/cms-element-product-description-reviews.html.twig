{% sw_extends '@Storefront/storefront/element/cms-element-product-description-reviews.html.twig' %}
{% block element_product_description_reviews %}
    {% set productOnRequest = page.product.translated.customFields.ww_vibraplast_product_on_request %}
    {% set shouldHideBuy = (productOnRequest == 'yes_not_purchasable') %}
    {% if not shouldHideBuy %}
        <div class="product-detail-buy">
            {% sw_include '@WebwirkungVibraplastTheme/storefront/component/product/variants-buy-table.html.twig' with { data: fetchVariantsTableData(page.product.parentId??page.product.id, context) } %}
        </div>
    {% endif %}

    {% block page_product_detail_tabs %}
        <div class="product-detail-tabs">
            {% sw_include '@Storefront/storefront/page/product-detail/tabs.html.twig' %}
        </div>
    {% endblock %}
{% endblock %}
