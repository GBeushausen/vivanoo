{% set price = page.product.calculatedPrice %}
{% if variantPrice %}
    {% set price = variantPrice %}
{% endif %}

<meta itemprop="price"
      content="{{ price.unitPrice }}">

{% block page_product_detail_price_content %}
    {% set listPrice = price.listPrice %}
    {% set isListPrice = listPrice.percentage > 0 %}
    {% set isRegulationPrice = price.regulationPrice != null %}
    {% set computed = wwComputedQuantityUnit(variant, context) %}
    <div class="product-detail-price-wrapper">
        <span class="product-detail-price{% if isListPrice %} with-list-price{% endif %}{% if isRegulationPrice %} with-regulation-price{% endif %}">
            {% set perUnitData = wwPerUnitPricing(price.extensions.abacus_base_unit_price.price, variant, context) %}
            {% if perUnitData and perUnitData.unitHtml %}
                <span class="product-detail-price-unit">
                    {{ perUnitData.value|currency }}
                </span> {{ "general.star"|trans|sw_sanitize }} /{{ perUnitData.unitHtml|raw }}
                <br>
            {% endif %}
            {% if not perUnitData or not perUnitData.hidePiecePrice %}
                <span class="product-detail-price-pce">
                {{ price.unitPrice|currency }}{{ "general.star"|trans|sw_sanitize }} {{ 'product.detail.variant-configurator.perUnit'|trans }}
            </span>
            {% endif %}
            <input type="hidden" name="product-id" value="{{ variant.id }}">
            {% if computed %}
                <input type="hidden" name="calculated-quantity" value="{{ computed.quantity }}">
            {% endif %}
        </span>

        {% if isListPrice %}
            {% block page_product_detail_was_price %}

                {% block page_product_detail_was_price_badge %}
                {% endblock %}

                {% set afterListPriceSnippetExists = "listing.afterListPrice"|trans|length > 0 %}
                {% set beforeListPriceSnippetExists = "listing.beforeListPrice"|trans|length > 0 %}

                {% block page_product_detail_was_price_wrapper %}
                    <span class="product-detail-list-price-wrapper">
                        {% if beforeListPriceSnippetExists %}{{ "listing.beforeListPrice"|trans|trim }}{% endif %}

                        <span{% if not (afterListPriceSnippetExists or beforeListPriceSnippetExists) %} class="list-price-price"{% endif %}>
                            {% set perUnitList = wwPerUnitPricing(listPrice.price, variant, context.context) %}
                            {% if perUnitList and perUnitList.unitHtml %}
                                {{ perUnitList.value|currency }}{{ "general.star"|trans|sw_sanitize }} /{{ perUnitList.unitHtml|raw }}
                                <br>
                            {% endif %}
                            {% if not perUnitData or not perUnitData.hidePiecePrice %}
                                <span class="product-detail-list-price-pce">
                                    {{ listPrice.price|currency }}{{ "general.star"|trans|sw_sanitize }} {{ 'product.detail.variant-configurator.perUnit'|trans }}
                                </span>
                            {% endif %}
                        </span>

                        {% if afterListPriceSnippetExists %}
                            {{ "listing.afterListPrice"|trans|trim }}
                        {% endif %}

                        {#                    <span class="list-price-percentage">{{ "detail.listPricePercentage"|trans({'%price%': listPrice.percentage })|sw_sanitize }}</span> #}
                    </span>
                {% endblock %}
            {% endblock %}
        {% endif %}
    </div>
    {% if isRegulationPrice %}
        <span class="product-detail-list-price-wrapper">
            <span class="regulation-price">{{ "general.listPricePreviously"|trans({'%price%': price.regulationPrice.price|currency }) }}{{ "general.star"|trans|sw_sanitize }}</span>
        </span>
    {% endif %}
{% endblock %}
