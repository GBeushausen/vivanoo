        {% sw_icon 'account' style {'pack' : 'WebwirkungIcons'} %}
        <a href="#loginCollapse"
           class="login-collapse-toggle"
           data-bs-toggle="collapse"
           aria-expanded="false">
            <strong>{{ "checkout.addressLoginToggle"|trans|sw_sanitize }}</strong> </a>
    </div>
{% endblock %}