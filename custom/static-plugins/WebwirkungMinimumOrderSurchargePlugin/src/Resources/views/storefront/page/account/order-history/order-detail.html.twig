{% sw_extends '@Storefront/storefront/page/account/order-history/order-detail.html.twig' %}

{% block page_account_order_item_detail_shipping_costs %}

    {{ parent() }}

    {% set isMinimumOrderSurchargeValue = order.customFields.minimumOrderSurcharge.totalPrice is defined
        and order.customFields.minimumOrderSurcharge.totalPrice is not null
        and order.customFields.minimumOrderSurcharge.totalPrice > 0 %}

    {% if isMinimumOrderSurchargeValue > 0 %}

        {% block page_account_order_item_detail_minimum_order_surcharge_label %}
            <dt class="col-6 col-md-8">
                {{ "WebwirkungMinimumOrderSurcharge.checkout.minimumOrderSurchargeAmount"|trans|sw_sanitize }}
            </dt>
        {% endblock %}

        {% block page_account_order_item_detail_minimum_order_surcharge_value %}
            <dd class="col-6 col-md-4">{{ order.customFields.minimumOrderSurcharge.totalPrice|currency(order.currency.isoCode) }}</dd>
        {% endblock %}

    {% endif %}

{% endblock %}
