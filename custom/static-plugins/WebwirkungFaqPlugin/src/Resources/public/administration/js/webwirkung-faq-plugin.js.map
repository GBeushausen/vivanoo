export default "{% block webwirkung_faq_category_detail %}\n    <sw-page class=\"webwirkung-faq-category-detail\">\n        <template #language-switch>\n            <sw-language-switch\n                    v-if=\"changedToDefaultLanguage || !faqCategory.name\"\n                    disabled>\n            </sw-language-switch>\n            <sw-language-switch\n                    v-if=\"!changedToDefaultLanguage && faqCategory.name\"\n                    @on-change=\"changeLanguageSelection\"\n                    :saveChangesFunction=\"saveOnLanguageChange\">\n            </sw-language-switch>\n        </template>\n        <template #smart-bar-actions>\n            <sw-button :routerLink=\"{ name: 'webwirkung.faq.category.list' }\">\n                {{ $t('faq-category.detail.cancelButtonText') }}\n            </sw-button>\n\n            <sw-button-process\n                    :isLoading=\"isLoading\"\n                    :processSuccess=\"processSuccess\"\n                    variant=\"primary\"\n                    @process-finish=\"saveFinish\"\n                    @click=\"onClickSave\">\n                {{ $t('faq-category.detail.saveButtonText') }}\n            </sw-button-process>\n        </template>\n\n        <template #content>\n            <sw-card-view>\n                <div v-if=\"changedToDefaultLanguage\">\n                    <p class=\"sw-language-info\">\n                        <span class=\"sw_language-info__info\">\n                            {{ $t('faq.detail.infoDefaultLanguage') }}\n                        </span>\n                    </p>\n                </div>\n                <sw-card v-if=\"faqCategory\" :isLoading=\"isLoading\">\n                    <div v-if=\"!faqCategory.name && hasError\" class=\"sw-field__error\" style=\"margin-bottom: 5px;\">\n                        {{ $t('faq.detail.nameRequiredErrorMessage') }}\n                    </div>\n                    <sw-field :label=\"$t('faq-category.general.nameField')\" v-model=\"faqCategory.name\"></sw-field>\n                </sw-card>\n            </sw-card-view>\n        </template>\n\n    </sw-page>\n{% endblock %}\n";