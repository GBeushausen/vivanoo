export default "{% block sw_cms_element_faq_select_element_config %}\n    <div class=\"sw-cms-el-config-faq-select-element\">\n        <sw-entity-multi-select\n            :placeholder=\"$tc('faq.elements.select.selectFieldLabel')\"\n            :label=\"$tc('faq.elements.select.selectFieldLabel')\"\n            entity=\"ww_faq\"\n            :context=\"faqMultiSelectContext\"\n            v-model=\"faqCollection\"\n            @change=\"onFaqChange\">\n\n            <template #selection-label-property=\"{ item }\">\n                <slot name=\"selection-label-property\" v-bind=\"{ item }\">\n                    {{ item.question }} ({{ item.variant }})\n                </slot>\n            </template>\n\n            <template #result-item=\"{ item, index }\">\n                <slot name=\"result-item\" v-bind=\"{ item, index }\">\n                    <li is=\"sw-select-result\" v-bind=\"{ item, index }\">\n                        {{ item.question }} ({{ item.variant }})\n                    </li>\n                </slot>\n            </template>\n        </sw-entity-multi-select>\n    </div>\n{% endblock %}\n";