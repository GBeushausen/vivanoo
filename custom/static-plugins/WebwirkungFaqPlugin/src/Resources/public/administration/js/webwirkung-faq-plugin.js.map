export default "{% block webwirkung_faq_list %}\n    <sw-page class=\"webwirkung-faq-list\">\n        <template #language-switch>\n            <sw-language-switch\n                    @on-change=\"changeLanguageSelection\">\n            </sw-language-switch>\n        </template>\n        {% block webwirkung_faq_list_smart_bar_actions %}\n            <template slot=\"smart-bar-actions\">\n                <sw-button variant=\"primary\" :routerLink=\"{ name: 'webwirkung.faq.create' }\">\n                    {{ $t('faq.list.addButtonText') }}\n                </sw-button>\n            </template>\n        {% endblock %}\n        <template #sidebar>\n            {% block faq_side_content %}\n                <faq-vertical-tabs />\n            {% endblock %}\n        </template>\n\n        <template #content>\n            {% block webwirkung_faq_list_content %}\n                <sw-entity-listing\n                        v-if=\"faq\"\n                        :items=\"faq\"\n                        :showSelection=\"false\"\n                        :columns=\"columns\"\n                        :repository=\"repository\"\n                        detailRoute=\"webwirkung.faq.detail\">\n                </sw-entity-listing>\n            {% endblock %}\n        </template>\n    </sw-page>\n{% endblock %}\n";