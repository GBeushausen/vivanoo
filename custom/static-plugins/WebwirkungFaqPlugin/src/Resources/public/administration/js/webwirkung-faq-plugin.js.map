export default "{% block webwirkung_faq_detail %}\n    <sw-page class=\"webwirkung-faq-detail\">\n        <template #language-switch>\n            <sw-language-switch\n                    v-if=\"changedToDefaultLanguage || !faq.question\"\n                    disabled>\n            </sw-language-switch>\n            <sw-language-switch\n                    v-if=\"!changedToDefaultLanguage && faq.question\"\n                    @on-change=\"changeLanguageSelection\"\n                    :saveChangesFunction=\"saveOnLanguageChange\">\n            </sw-language-switch>\n        </template>\n        <template #smart-bar-actions>\n            <sw-button :routerLink=\"{ name: 'webwirkung.faq.list' }\">\n                {{ $t('faq.detail.cancelButtonText') }}\n            </sw-button>\n\n            <sw-button-process\n                    :isLoading=\"isLoading\"\n                    :processSuccess=\"processSuccess\"\n                    variant=\"primary\"\n                    @process-finish=\"saveFinish\"\n                    @click=\"onClickSave\">\n                {{ $t('faq.detail.saveButtonText') }}\n            </sw-button-process>\n        </template>\n\n        <template #content>\n            <sw-card-view>\n                <div v-if=\"changedToDefaultLanguage\">\n                    <p class=\"sw-language-info\">\n                        <span class=\"sw_language-info__info\">\n                            {{ $t('faq.detail.infoDefaultLanguage') }}\n                        </span>\n                    </p>\n                </div>\n                <sw-card v-if=\"faq\" :isLoading=\"isLoading\">\n                    <div v-if=\"!faq.question && hasError\" class=\"sw-field__error\" style=\"margin-bottom: 5px;\">\n                        {{ $t('faq.detail.questionRequiredErrorMessage') }}\n                    </div>\n                    <sw-field\n                            :label=\"$t('faq.general.questionField')\"\n                            v-model=\"faq.question\"\n                    ></sw-field>\n                    <sw-text-editor\n                            :label=\"$t('faq.general.answerField')\"\n                            v-model=\"faq.answer\"\n                    ></sw-text-editor>\n\n                    <sw-entity-many-to-many-select\n                            :label=\"$t('faq.general.categoryField')\"\n                            v-model=\"faq.faqCategory\"\n                    >\n                    </sw-entity-many-to-many-select>\n                    <sw-field\n                            :label=\"$t('faq.general.variantField')\"\n                            v-model=\"faq.variant\"\n                    ></sw-field>\n                    <sw-switch-field\n                            v-model=\"faq.hidden\"\n                            :label=\"$t('faq.general.hiddenField')\">\n                    </sw-switch-field>\n                </sw-card>\n            </sw-card-view>\n        </template>\n    </sw-page>\n{% endblock %}\n";