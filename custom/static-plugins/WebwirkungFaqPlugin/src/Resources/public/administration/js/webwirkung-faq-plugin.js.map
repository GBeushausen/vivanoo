export default "<sw-tabs isVertical :defaultItem=\"defaultItem\" :small=\"false\" class=\"faq__tabs\" @new-item-active=\"onChangeTab\" >\n    <template #default=\"{ active }\">\n        {% block webwirkung_block_list_tab_item %}\n        <sw-tabs-item title=\"$t('faq.general.mainMenuItemList')\"\n                      variant=\"minimal\"\n                      :route=\"{ name: 'webwirkung.faq.list' }\"\n                      :activeTab=\"active\"\n                      :native=\"true\"\n                      name=\"faq\">\n            {{ $t('faq.general.mainMenuItemList') }}\n        </sw-tabs-item>\n        {% endblock %}\n\n        {% block webwirkung_block_faq_category_tab_item %}\n        <sw-tabs-item title=\"$t('faq-category.general.mainMenuItemList')\"\n                      :route=\"{ name: 'webwirkung.faq.category.list' }\"\n                      variant=\"minimal\"\n                      :activeTab=\"active\"\n                      :native=\"true\"\n                      name=\"author\">\n            {{ $t('faq-category.general.mainMenuItemList') }}\n        </sw-tabs-item>\n        {% endblock %}\n    </template>\n</sw-tabs>\n";