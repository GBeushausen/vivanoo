{% block webwirkung_element_faq_listing_row %}
    <div class="cms-block-faq-listing cms-news-full-listing-row js-listing-wrapper">
        {% if searchResult.total > 0 %}
            {% block webwirkung_element_faq_listing_col %}
                <div class="accordion-faq-category-wrapper accordion__list" data-accordion-plugin>
                    <div class="row">
                        {% for faqCategory in searchResult %}
                            {% if faqCategory.faq.elements|length > 0 %}
                                <div class="accordion-faq">
                                    <span class="accordion__title">
                                        <span class="arrow"></span>{{ faqCategory.translated.name }}
                                    </span>
                                    <div class="accordion__content-wrap">
                                        <div class="accordion__content">
                                            <div class="row">
                                                <div class="col-12">
                                                    {% for faq in faqCategory.faq %}
                                                        {% if faq.hidden is not true %}
                                                            {% sw_include '@Storefront/storefront/component/faq/card/box.html.twig' %}
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endblock %}
        {% else %}
            {% block webwirkung_element_faq_listing_col_empty %}
                <div class="cms-listing-col col-12">
                    {% block webwirkung_element_faq_listing_col_empty_alert %}
                        {% sw_include '@Storefront/storefront/utilities/alert.html.twig' with {
                            type: 'info',
                            content: 'faq.search.emptyResult'|trans|sw_sanitize
                        } %}
                    {% endblock %}
                </div>
            {% endblock %}
        {% endif %}
    </div>
{% endblock %}
