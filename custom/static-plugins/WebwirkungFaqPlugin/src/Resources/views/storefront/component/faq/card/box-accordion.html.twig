{% block webwirkung_faq_card %}
    {% block webwirkung_faq_card_body %}
        {% block webwirkung_faq_card_title_date %}
            <span class="accordion__title">
                <span class="title">{{ faq.translated.question }}</span><span class="arrow"></span>
            </span>
            <div class="accordion__content-wrap">
                <div class="accordion__content">
                    {{ faq.translated.answer|raw }}
                </div>
            </div>
        {% endblock %}
    {% endblock %}
{% endblock %}