{% block webwirkung_faq_detail %}
    <sw-page class="webwirkung-faq-detail">
        <template #language-switch>
            <sw-language-switch
                    v-if="changedToDefaultLanguage || !faq.question"
                    disabled>
            </sw-language-switch>
            <sw-language-switch
                    v-if="!changedToDefaultLanguage && faq.question"
                    @on-change="changeLanguageSelection"
                    :saveChangesFunction="saveOnLanguageChange">
            </sw-language-switch>
        </template>
        <template #smart-bar-actions>
            <sw-button :routerLink="{ name: 'webwirkung.faq.list' }">
                {{ $t('faq.detail.cancelButtonText') }}
            </sw-button>

            <sw-button-process
                    :isLoading="isLoading"
                    :processSuccess="processSuccess"
                    variant="primary"
                    @process-finish="saveFinish"
                    @click="onClickSave">
                {{ $t('faq.detail.saveButtonText') }}
            </sw-button-process>
        </template>

        <template #content>
            <sw-card-view>
                <div v-if="changedToDefaultLanguage">
                    <p class="sw-language-info">
                        <span class="sw_language-info__info">
                            {{ $t('faq.detail.infoDefaultLanguage') }}
                        </span>
                    </p>
                </div>
                <sw-card v-if="faq" :isLoading="isLoading">
                    <div v-if="!faq.question && hasError" class="sw-field__error" style="margin-bottom: 5px;">
                        {{ $t('faq.detail.questionRequiredErrorMessage') }}
                    </div>
                    <sw-text-field
                            :label="$t('faq.general.questionField')"
                            v-model:value="faq.question"
                    ></sw-text-field>
                    <sw-text-editor
                            :label="$t('faq.general.answerField')"
                            v-model:value="faq.answer"
                    ></sw-text-editor>

                    <sw-entity-many-to-many-select
                            :label="$t('faq.general.categoryField')"
                            v-model:value="faq.faqCategory"
                    >
                    </sw-entity-many-to-many-select>
                    <sw-text-field
                            :label="$t('faq.general.variantField')"
                            v-model:value="faq.variant"
                    ></sw-text-field>
                    <sw-switch-field
                            v-model:value="faq.hidden"
                            :label="$t('faq.general.hiddenField')">
                    </sw-switch-field>
                </sw-card>
            </sw-card-view>
        </template>
    </sw-page>
{% endblock %}
