<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true"/>
        <prototype namespace="Webwirkung\ProductFinder\" resource="../../"/>

        <service id="Webwirkung\ProductFinder\Storefront\Controller\ProductFinderController">
            <argument key="$listingRoute" type="service" id="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingRoute"/>
        </service>
    </services>
</container>