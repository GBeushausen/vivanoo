export default "{% block webwirkung_glossary_list %}\n    <sw-page class=\"glossary-list\">\n        <template #language-switch>\n            <sw-language-switch\n                    @on-change=\"changeLanguageSelection\">\n            </sw-language-switch>\n        </template>\n        {% block webwirkung_glossary_list_smart_bar_actions %}\n            <template #smart-bar-actions>\n                <sw-button variant=\"primary\" :routerLink=\"{ name: 'webwirkung.glossary.create' }\">\n                    {{ $t('webwirkung.glossary.list.addButtonText') }}\n                </sw-button>\n            </template>\n        {% endblock %}\n\n        <template #content>\n            {% block webwirkung_glossary_list_content %}\n                <sw-entity-listing\n                        v-if=\"glossary\"\n                        :items=\"glossary\"\n                        :showSelection=\"false\"\n                        :columns=\"columns\"\n                        :repository=\"repository\"\n                        detailRoute=\"webwirkung.glossary.detail\">\n                </sw-entity-listing>\n            {% endblock %}\n        </template>\n    </sw-page>\n{% endblock %}\n";